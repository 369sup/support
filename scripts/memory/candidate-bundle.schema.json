{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://support.local/schemas/serena-memory-candidate-bundle.schema.json",
  "title": "Support Serena memory candidate bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "checkpointToken", "disposition", "candidates"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "checkpointToken": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128
    },
    "disposition": {
      "enum": ["distill", "no-memory"]
    },
    "candidates": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/candidate"
      }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "reference"],
      "properties": {
        "type": {
          "enum": [
            "user-instruction",
            "repository-file",
            "test-result",
            "diagnostic",
            "tool-observation"
          ]
        },
        "reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "scope",
        "subject",
        "statement",
        "status",
        "authority",
        "confidence",
        "durability",
        "evidence",
        "invalidatedBy"
      ],
      "properties": {
        "kind": {
          "enum": [
            "decision",
            "constraint",
            "verified-result",
            "environment",
            "workflow",
            "unresolved"
          ]
        },
        "scope": {
          "enum": ["task", "worktree", "repository", "environment"]
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "statement": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        },
        "status": {
          "enum": ["confirmed", "unresolved"]
        },
        "authority": {
          "enum": [
            "canonical",
            "user-decision",
            "verified-result",
            "repeated-observation",
            "inference"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "durability": {
          "enum": ["episode", "working", "durable"]
        },
        "evidence": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "invalidatedBy": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 180
          }
        }
      }
    }
  }
}
