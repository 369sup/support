# Canonical public URL used by metadata routes in deployed environments.
NEXT_PUBLIC_SITE_URL=

# Structured server logging. Supported values: debug, info, warn, error, silent.
LOG_LEVEL=info

# OpenTelemetry is opt-in. Leave the endpoint empty to disable trace and metric export.
OTEL_SERVICE_NAME=support-web
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional standard OpenTelemetry resource attributes and authentication headers.
OTEL_RESOURCE_ATTRIBUTES=
OTEL_EXPORTER_OTLP_HEADERS=
